{
  "name": "value-search",
  "version": "1.0.0",
  "description": "Amazon.co.jpの書籍ページにバリューブックスの在庫状況と価格を表示するブラウザ拡張機能",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "clean:releases": "rm -rf releases",
    "build:chrome": "node scripts/build.ts chrome",
    "build:chrome:prod": "node scripts/build.ts chrome --prod",
    "build:chrome:all": "npm run clean && npm run build:chrome",
    "build:chrome:prod:all": "npm run clean && npm run build:chrome:prod",
    "watch:chrome": "node scripts/build.ts chrome --watch",
    "package:chrome": "npm run build:chrome:prod:all && node scripts/package-chrome.ts",
    "build:firefox": "node scripts/build.ts firefox",
    "build:firefox:prod": "node scripts/build.ts firefox --prod",
    "build:firefox:all": "npm run clean && npm run build:firefox",
    "build:firefox:prod:all": "npm run clean && npm run build:firefox:prod",
    "watch:firefox": "node scripts/build.ts firefox --watch",
    "package:firefox": "npm run build:firefox:prod:all && node scripts/package-firefox.ts",
    "sign:firefox": "node scripts/sign-firefox.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/okayu9/value-search.git"
  },
  "engines": {
    "node": ">=24"
  },
  "author": "Yumeto Inaoka",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/okayu9/value-search/issues"
  },
  "homepage": "https://github.com/okayu9/value-search#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/archiver": "^6.0.3",
    "@types/chrome": "^0.0.313",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "archiver": "^7.0.1",
    "esbuild": "^0.25.2",
    "jsdom": "^29.0.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
