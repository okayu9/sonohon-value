# Firefox アドオンの署名・公開に使用する環境変数。
# このファイルを .env にコピーして値を設定してください。
# 詳細は docs/operations.md を参照。

# ── 必須（署名時） ──────────────────────────
# AMO の JWT 認証キー（https://addons.mozilla.org/developers/addon/api/key/）
WEB_EXT_API_KEY=
WEB_EXT_API_SECRET=

# Firefox 拡張機能 ID（例: your-addon@example.com）
WEB_EXT_GECKO_ID=

# ── 任意 ────────────────────────────────────
# 署名チャンネル: listed（AMO 公開）または unlisted（自己配布）。デフォルト: unlisted
# WEB_EXT_CHANNEL=unlisted

# AMO に表示されるライセンス識別子。デフォルト: all-rights-reserved
# WEB_EXT_AMO_LICENSE=Apache-2.0

# AMO に表示される概要文
# WEB_EXT_AMO_SUMMARY=Amazon.co.jpの書籍ページにバリューブックスの在庫と価格を表示します。

# AMO カテゴリ（カンマ区切り）。デフォルト: other
# WEB_EXT_AMO_CATEGORIES=shopping
